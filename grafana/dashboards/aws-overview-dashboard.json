{
  "title": "AWS Infrastructure Overview",
  "uid": "aws-infra-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "EC2 CPU Utilization (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "percent"
        }
      }
    },
    {
      "id": 2,
      "title": "RDS Free Storage Space",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "aws_rds_free_storage_space_average",
          "legendFormat": "{{dbinstance_identifier}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 3,
      "title": "ALB 5xx Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(aws_applicationelb_httpcode_target_5_xx_count_sum[5m])) by (load_balancer)",
          "legendFormat": "{{load_balancer}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Lambda Errors (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(aws_lambda_errors_sum[5m])) by (function_name)",
          "legendFormat": "{{function_name}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Targets / Instances Up vs Down",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "sum(up)", "legendFormat": "Up" },
        { "expr": "count(up == 0)", "legendFormat": "Down" }
      ]
    },
    {
      "id": 6,
      "title": "EKS Pod Restarts (15m)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "increase(kube_pod_container_status_restarts_total[15m])",
          "legendFormat": "{{namespace}}/{{pod}}"
        }
      ]
    }
  ]
}
